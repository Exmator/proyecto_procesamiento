    "for c in columnas_texto:\n",
    "    if c in dfPy02.columns:\n",
    "        dfPy02 = dfPy02.withColumn(c, F.upper(F.trim(F.col(c))))\n",
    "\n",
    "dfPy02.printSchema()"
